# Server
PORT=3001
NODE_ENV=development

# Supabase (Service Role - Full Access)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT
JWT_SECRET=your_jwt_secret_key_min_32_chars_long
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Talyn <noreply@talynx.org>

# Stripe (Employer bank account linking)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Wise (Employee payouts - USD to NPR)
WISE_API_TOKEN=your_wise_api_token
WISE_PROFILE_ID=your_wise_profile_id
WISE_WEBHOOK_SECRET=your_wise_webhook_secret

# Admin
ADMIN_EMAIL=admin@yourdomain.com
